# AgentLink Platform Environment Variables

# Database
DATABASE_URL="file:./dev.db"
# Für PostgreSQL/Supabase:
# DATABASE_URL="postgresql://user:password@localhost:5432/agentlink"

# Blockchain
NETWORK="base-sepolia"
RPC_URL="https://sepolia.base.org"

# Smart Contract Addresses (Testnet - Security Fixed Version)
AGENT_REPUTATION_CONTRACT="0x7C56670BA983546A650e70E8D106631d69a56000"
PAYMENT_ROUTER_CONTRACT="0xf17EDf5B92aAa0b7a3FE7D123906c71f94516D59"
USDC_CONTRACT="0x036CbD53842c5426634e7929541eC2318f3dCF7e"

# Platform Configuration
PLATFORM_FEE_PERCENT="100"
NEXT_PUBLIC_PLATFORM_NAME="AgentLink"
NEXT_PUBLIC_NETWORK="base-sepolia"

# API Keys (optional)
# ETHERSCAN_API_KEY=""
# ALCHEMY_API_KEY=""
# INFURA_API_KEY=""

# Webhook Secret (für Agent Messaging)
WEBHOOK_SECRET="your-webhook-secret-here"

# Für Production (Mainnet):
# NETWORK="base-mainnet"
# RPC_URL="https://mainnet.base.org"
# AGENT_REPUTATION_CONTRACT="0x..."
# PAYMENT_ROUTER_CONTRACT="0x..."
# USDC_CONTRACT="0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"
